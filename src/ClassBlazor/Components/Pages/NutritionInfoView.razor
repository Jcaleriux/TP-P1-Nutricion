@inject SessionService SessionService

<h3 class="main-form-welcome mb-4">Nutrition Information</h3>

@if (SessionService.CurrentUser is null)
{
    <p>Redirecting...</p>
}
else
{
    <div class="nutrition-info-list">
        <p><strong>BMI:</strong> @bmi.ToString("F2")</p>
        <p><strong>Category:</strong> @bmiCategory</p>
        <p><strong>Maintenance Calories:</strong> @maintenanceCalories.ToString("F2") kcal</p>
        <p><strong>Goal Calories:</strong> @goalCalories.ToString("F2") kcal</p>
        <p><strong>Protein:</strong> @protein.ToString("F2") g</p>
        <p><strong>Carbs:</strong> @carbs.ToString("F2") g</p>
        <p><strong>Fat:</strong> @fat.ToString("F2") g</p>
    </div>
}

@code {
    private decimal bmi;
    private string bmiCategory = "";
    private decimal maintenanceCalories;
    private decimal goalCalories;
    private decimal protein;
    private decimal carbs;
    private decimal fat;

    protected override void OnInitialized()
    {
        if (SessionService.CurrentUser is null)
        {
            return;
        }

        LoadNutritionInfo();
    }

    private void LoadNutritionInfo()
    {
        var user = SessionService.CurrentUser!;

        bmi = NutritionCalculator.CalculateBmi(user);
        bmiCategory = NutritionCalculator.GetBmiCategory(bmi);
        maintenanceCalories = NutritionCalculator.CalculateMaintenanceCalories(user);
        goalCalories = NutritionCalculator.CalculateGoalCalories(user);

        var macros = NutritionCalculator.CalculateMacroTargets(user);

        protein = macros.Protein;
        carbs = macros.Carbs;
        fat = macros.Fat;
    }
}
