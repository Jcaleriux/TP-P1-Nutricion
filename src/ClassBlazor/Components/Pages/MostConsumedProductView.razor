@inject SessionService SessionService
@inject ProductController ProductController

<PageTitle>Most Consumed Product</PageTitle>

@if (SessionService.CurrentUser?.Role != "Admin")
{
    <p class="most-consumed-message most-consumed-message-error">Access denied.</p>
}
else
{
    <section class="most-consumed-shell">
        <h3 class="main-form-welcome mb-4">Most Consumed Product</h3>

        <p class="most-consumed-note">
            Select a date range to see which product was consumed the most.
        </p>

        <div class="most-consumed-fields">
            <div class="form-floating">
                <input type="date" @bind="startDate" class="form-control" id="mostConsumedStartDate" />
                <label for="mostConsumedStartDate">Start date</label>
            </div>

            <div class="form-floating">
                <input type="date" @bind="endDate" class="form-control" id="mostConsumedEndDate" />
                <label for="mostConsumedEndDate">End date</label>
            </div>
        </div>

        <div class="most-consumed-actions">
            <button @onclick="Calculate" class="btn btn-success w-100 py-2" type="button">
                Calculate
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(result))
        {
            <p class="most-consumed-result mb-0">@result</p>
        }
    </section>
}

@code {
    private DateTime startDate = DateTime.Today;
    private DateTime endDate = DateTime.Today;
    private string result = string.Empty;
    private void Calculate()
    {
        if (startDate > endDate)
        {
            result = "Start date cannot be later than end date.";
            return;
        }

        var product = ProductController.GetMostConsumedProduct(startDate, endDate);
        result = product != null
            ? $"Most consumed product: {product.Name}"
            : "No data available for the selected range.";
    }
}
