@page "/main"

@inject NavigationManager Navigation
@inject SessionService SessionService

<PageTitle>Main Page</PageTitle>
<HeadContent>
    <link rel="stylesheet" href="/css/MainForm.css" />
    <link rel="stylesheet" href="/css/ProductView.css" />
    <link rel="stylesheet" href="/css/MenuView.css" />
    <link rel="stylesheet" href="/css/StatisticsView.css" />
</HeadContent>

@if (SessionService.CurrentUser is null)
{
    <p>Welcome</p>
    <button @onclick="GoToLogin">Go to login</button>
}
else
{
    <main class="main-form-layout d-flex flex-nowrap">
        <div class="main-form-sidebar d-flex flex-column flex-shrink-0 p-3">
            <a href="/main" class="main-form-brand d-flex align-items-center text-decoration-none">
                <img class="main-form-brand-logo" src="/images/logo.png" alt="Logo NutriMenu" width="50" height="50" />
                <span class="main-form-brand-title fs-2 fw-bold">NutriMenu</span>
            </a>

            <hr />

            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <button type="button" @onclick="ShowHome" class="@GetNavLinkClass(ViewSection.Home)"
                            aria-current="page">
                        <svg class="bi pe-none me-2" width="16" height="16" aria-hidden="true">
                            <use xlink:href="#home"></use>
                        </svg>
                        Home
                    </button>
                </li>
                <li>
                    <button type="button" @onclick="ShowProducts" class="@GetNavLinkClass(ViewSection.Products)">
                        <svg class="bi pe-none me-2" width="16" height="16" aria-hidden="true">
                            <use xlink:href="#speedometer2"></use>
                        </svg>
                        Products
                    </button>
                </li>
                <li>
                    <button type="button" @onclick="ShowMenus" class="@GetNavLinkClass(ViewSection.Menus)">
                        <svg class="bi pe-none me-2" width="16" height="16" aria-hidden="true">
                            <use xlink:href="#table"></use>
                        </svg>
                        Menus
                    </button>
                </li>
                <li>
                    <button type="button" @onclick="ShowStatistics" class="@GetNavLinkClass(ViewSection.Statistics)">
                        <svg class="bi pe-none me-2" width="16" height="16" aria-hidden="true">
                            <use xlink:href="#grid"></use>
                        </svg>
                        Statistics
                    </button>
                </li>
                @if (IsAdmin)
                {
                    <li>
                        <button type="button" @onclick="GoToUserManagement" class="main-form-nav-link nav-link">
                            <svg class="bi pe-none me-2" width="16" height="16" aria-hidden="true">
                                <use xlink:href="#people-circle"></use>
                            </svg>
                            User Management
                        </button>
                    </li>
                    <li>
                        <button type="button" @onclick="GoToMostConsumedProduct" class="main-form-nav-link nav-link">
                            <svg class="bi pe-none me-2" width="16" height="16" aria-hidden="true">
                                <use xlink:href="#bar-chart"></use>
                            </svg>
                            Most Consumed Product
                        </button>
                    </li>
                }
            </ul>

            <hr />

            <div class="dropdown">
                <a href="#" @onclick:preventDefault="true"
                       class="main-form-user-link d-flex align-items-center text-decoration-none dropdown-toggle"
                       data-bs-toggle="dropdown" aria-expanded="false">
                    <svg class="bi pe-none me-2" width="16" height="16" aria-hidden="true">
                        <use xlink:href="#people-circle"></use>
                    </svg>
                    <strong class="fs-4">@UserName</strong>
                </a>
                <ul class="dropdown-menu text-small shadow">
                    <li><a @onclick="Logout" @onclick:preventDefault="true" class="dropdown-item" href="#">Sign out</a></li>
                </ul>
            </div>
        </div>

        <section class="main-form-content flex-grow-1 p-4">
            @if (CurrentSection == ViewSection.Home)
            {
                <div class="main-form-header">
                    <h3 class="main-form-welcome mb-4">@WelcomeMessage</h3>
                </div>
            }

            <div class="main-form-body">
                @switch (CurrentSection)
                {
                    case ViewSection.Home:
                        <div class="main-form-panel">
                            <NutritionInfoView />
                        </div>
                        break;
                    case ViewSection.Products:
                        <div class="main-form-panel">
                            <ProductView />
                        </div>
                        break;
                    case ViewSection.Menus:
                        <div class="main-form-panel main-form-panel-wide">
                            <MenuView />
                        </div>
                        break;
                    case ViewSection.Statistics:
                        <div class="main-form-panel main-form-panel-wide">
                            <StatisticsView />
                        </div>
                        break;
                    default:
                        <div class="main-form-panel">
                            <p>Select an option from the sidebar.</p>
                        </div>
                        break;
                }
            </div>
        </section>
    </main>
}

@code {
    private ViewSection CurrentSection = ViewSection.Home;

    private string UserName =>
        SessionService.CurrentUser is null
            ? string.Empty
            : SessionService.CurrentUser.Name;

    private string WelcomeMessage =>
        SessionService.CurrentUser is null
            ? "Welcome"
            : $"Welcome {SessionService.CurrentUser.Name}!";

    private bool IsAdmin => SessionService.CurrentUser?.Role == "Admin";

    protected override void OnInitialized()
    {
        if (SessionService.CurrentUser is null)
        {
            Navigation.NavigateTo("/");
        }
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/");
    }

    private void ShowHome()
    {
        CurrentSection = ViewSection.Home;
    }
    
    private void ShowProducts()
    {
        CurrentSection = ViewSection.Products;
    }

    private void ShowMenus()
    {
        CurrentSection = ViewSection.Menus;
    }

    private void ShowStatistics()
    {
        CurrentSection = ViewSection.Statistics;
    }

    private void Logout()
    {
        SessionService.CurrentUser = null;
        Navigation.NavigateTo("/");
    }

    private void GoToUserManagement()
    {
        Navigation.NavigateTo("/user-management");
    }

    private string GetNavLinkClass(ViewSection section)
    {
        return CurrentSection == section
            ? "main-form-nav-link nav-link active"
            : "main-form-nav-link nav-link";
    }

    private void GoToMostConsumedProduct()
    {
        Navigation.NavigateTo("/most-consumed");
    }

    private enum ViewSection
    {
        Home,
        Products,
        Menus,
        Statistics
    }
}
