@page "/main"

@inject NavigationManager Navigation
@inject SessionService SessionService

<PageTitle>Main Form</PageTitle>

<h1>Nutrition For Everyone</h1>

@if (SessionService.CurrentUser is null)
{
    <p>Welcome</p>
    <button @onclick="GoToLogin">Go to login</button>
}
else
{
    <p>@WelcomeMessage</p>

    <button @onclick="GoToProducts">Manage Products</button>
    <button @onclick="GoToMenus">Manage Menus</button>
    <button @onclick="GoToNutrition">Nutrition Info</button>
    <button @onclick="@(() => ShowMessage("Statistics"))">Statistics</button>
    <button @onclick="Logout">Cerrar sesión</button>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p>@message</p>
    }
}

@code {
    private string message = string.Empty;

    private string WelcomeMessage =>
        SessionService.CurrentUser is null
            ? "Welcome"
            : $"Welcome {SessionService.CurrentUser.Name}";

    protected override void OnInitialized()
    {
        if (SessionService.CurrentUser is null)
        {
            Navigation.NavigateTo("/");
        }
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/");
    }

    private void GoToProducts()
    {
        Navigation.NavigateTo("/products");
    }

    private void GoToMenus()
    {
        Navigation.NavigateTo("/menus");
    }

    private void ShowMessage(string section)
    {
        message = $"{section} is not available yet.";
    }

    private void GoToNutrition()
    {
        Navigation.NavigateTo("/nutritionInfo");
    }

    private void Logout()
    {
        SessionService.CurrentUser = null;
        Navigation.NavigateTo("/");
    }
}
