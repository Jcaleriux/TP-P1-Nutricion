@page "/register"

@inject LoginController loginController
@inject NavigationManager Navigation

<PageTitle>Register</PageTitle>
<HeadContent>
    <link rel="stylesheet" href="/css/RegisterView.css" />
</HeadContent>

<main class="register-page d-flex align-items-center py-4 bg-body-tertiary min-vh-100">
    <div class="register-form w-100 m-auto">
        <form>
            <img class="register-logo mb-4" src="/images/logo.png" alt="Logo de la aplicacion" width="250"
                 height="250" />
            <h1 class="h3 mb-3 fw-normal">Create your account</h1>

            <div class="register-fields">
                <div class="form-floating">
                    <input @bind="name" type="text" class="form-control" id="registerName" placeholder="Pedro Nuñez" />
                    <label for="registerName">Name</label>
                </div>

                <div class="form-floating">
                    <input @bind="email" type="email" class="form-control" id="registerEmail"
                           placeholder="name@example.com" />
                    <label for="registerEmail">Email</label>
                </div>

                <div class="form-floating">
                    <input @bind="password" type="password" class="form-control" id="registerPassword"
                           placeholder="Password" />
                    <label for="registerPassword">Password</label>
                </div>

                <div class="form-floating">
                    <input @bind="weight" type="text" class="form-control" id="registerWeight" placeholder="75" />
                    <label for="registerWeight">Weight (kg)</label>
                </div>

                <div class="form-floating">
                    <input @bind="height" type="text" class="form-control" id="registerHeight" placeholder="176" />
                    <label for="registerHeight">Height (cm)</label>
                </div>

                <div class="form-floating">
                    <input @bind="age" type="text" class="form-control" id="registerAge" placeholder="40" />
                    <label for="registerAge">Age</label>
                </div>

                <div class="form-floating">
                    <select @bind="goal" class="form-select" id="registerGoal">
                        <option value="">Select Goal</option>
                        @foreach (var g in goals)
                        {
                            <option value="@g">@g</option>
                        }
                    </select>
                    <label for="registerGoal">Goal</label>
                </div>

                <div class="form-floating">
                    <select @bind="activityLevel" class="form-select" id="registerActivityLevel">
                        <option value="">Activity Level</option>
                        @foreach (var a in activityLevels)
                        {
                            <option value="@a">@a</option>
                        }
                    </select>
                    <label for="registerActivityLevel">Activity Level</label>
                </div>

                <div class="form-floating">
                    <select @bind="sex" class="form-select" id="registerSex">
                        <option value="">Sex</option>
                        @foreach (var s in sexes)
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                    <label for="registerSex">Sex</label>
                </div>

                <div class="form-floating">
                    <select @bind="dietType" class="form-select" id="registerDietType">
                        <option value="">Diet Type</option>
                        @foreach (var d in dietTypes)
                        {
                            <option value="@d">@d</option>
                        }
                    </select>
                    <label for="registerDietType">Diet Type</label>
                </div>
            </div>

            <div class="register-actions mt-4">
                <button @onclick="Register" class="btn btn-success w-100 py-2" type="button">Register</button>
                <button @onclick="GoToLogin" class="btn btn-outline-secondary w-100 py-2" type="button">Go to
                    login</button>
                </div>

                @if (!string.IsNullOrEmpty(message))
                {
                    <p class="register-message mt-3 mb-0">@message</p>
                }
            </form>
        </div>
    </main>

@code {
    private string name = "";
    private string email = "";
    private string password = "";
    private string weight = "";
    private string height = "";
    private string age = "";
    private string goal = "";
    private string activityLevel = "";
    private string sex = "";
    private string dietType = "";

    private string message = "";

    private List<string> goals = new() { "Maintain", "LoseFat", "GainMass" };
    private List<string> activityLevels = new() { "Sedentary", "Light", "Moderate", "High" };
    private List<string> sexes = new() { "Male", "Female", "Other" };
    private List<string> dietTypes = new() { "Standard", "Keto", "Vegetarian" };

    private void Register()
    {
        if (!ValidateFields())
            return;

        var user = new User(
            0,
            name,
            email,
            password,
            goal,
            activityLevel,
            decimal.Parse(weight, System.Globalization.CultureInfo.InvariantCulture),
            decimal.Parse(height, System.Globalization.CultureInfo.InvariantCulture),
            int.Parse(age),
            sex,
            dietType
        );

        var result = loginController.Register(user);

        if (result)
        {
            Navigation.NavigateTo("/");
        }
        else
        {
            message = "This email is already registered.";
        }
    }

    private bool ValidateFields()
    {
        if (string.IsNullOrWhiteSpace(name) ||
            string.IsNullOrWhiteSpace(email) ||
            string.IsNullOrWhiteSpace(password) ||
            string.IsNullOrWhiteSpace(weight) ||
            string.IsNullOrWhiteSpace(height) ||
            string.IsNullOrWhiteSpace(age) ||
            string.IsNullOrWhiteSpace(goal) ||
            string.IsNullOrWhiteSpace(activityLevel) ||
            string.IsNullOrWhiteSpace(sex) ||
            string.IsNullOrWhiteSpace(dietType))
        {
            message = "All fields are required.";
            return false;
        }

        if (!decimal.TryParse(weight, out _))
        {
            message = "Weight must be a valid number.";
            return false;
        }

        if (!decimal.TryParse(height, out _))
        {
            message = "Height must be a valid number.";
            return false;
        }

        if (!int.TryParse(age, out _))
        {
            message = "Age must be a valid integer.";
            return false;
        }

        return true;
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/");
    }
}
